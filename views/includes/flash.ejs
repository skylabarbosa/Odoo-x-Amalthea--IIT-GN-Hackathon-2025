<% const successMessages = [].concat(success || [], success_msg || []); %>
<% if(successMessages.length) { %>
<div class="alert alert-success alert-dismissible fade show col-6 offset-3"
     role="alert">
    <%= successMessages[0] %>
    <button type="button" 
        class="btn-close" 
        data-bs-dismiss="alert" 
        aria-label="Close">
    </button>
</div>
<% } %>

<% const errorMessages = [].concat(error || [], error_msg || []); %>
<% if(errorMessages.length) { %>
<div class="alert alert-danger alert-dismissible fade show col-6 offset-3"
     role="alert">
    <%= errorMessages[0] %>
    <button type="button" 
        class="btn-close" 
        data-bs-dismiss="alert" 
        aria-label="Close">
    </button>
</div>
<% } %>
