<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <div class="card" style="max-width: 450px; width: 100%; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: white; font-size: 2rem; font-weight: 700;">
                E
            </div>
            <h1 class="card-title" style="margin-bottom: 0.5rem;">Welcome Back</h1>
            <p style="color: #64748b; font-size: 1rem;">Sign in to your account to continue</p>
        </div>
        
        <form action="/auth/login" method="POST">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password" required>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <label style="display: flex; align-items: center; font-size: 0.875rem; color: #64748b;">
                    <input type="checkbox" style="margin-right: 0.5rem;">
                    Remember me
                </label>
                <a href="#" style="color: #6366f1; text-decoration: none; font-size: 0.875rem;">Forgot password?</a>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem; margin-bottom: 1.5rem;">
                <i class="fas fa-sign-in-alt" style="margin-right: 0.5rem;"></i>
                Sign In
            </button>
        </form>
        
        <div style="text-align: center; padding-top: 1.5rem; border-top: 1px solid #e2e8f0;">
            <p style="color: #64748b; margin-bottom: 0;">
                Don't have an account? 
                <a href="/auth/signup" style="color: #6366f1; text-decoration: none; font-weight: 600;">Create a company (Admin)</a>
            </p>
            <p style="color: #64748b; margin-top: 0.5rem; margin-bottom: 0;">
                Employee or Manager?
                <a href="/auth/request-access" style="color: #6366f1; text-decoration: none; font-weight: 600;">Request access</a>
            </p>
        </div>
    </div>
</div>
