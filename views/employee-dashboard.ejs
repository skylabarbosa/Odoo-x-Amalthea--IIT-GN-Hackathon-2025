<!-- Welcome Section -->
<div class="card">
    <div class="d-flex justify-between align-center">
        <div>
            <h1 class="card-title">Welcome back, <%= user.name %>!</h1>
            <p class="text-gray-600">Manage your expenses and track your submissions</p>
        </div>
        <div class="text-right">
            <div class="status-badge status-pending">Active Employee</div>
        </div>
    </div>
</div>

<!-- Dashboard Grid -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
    <!-- Quick Stats -->
    <div class="card">
        <h3 class="card-title">Quick Stats</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="text-center p-3 rounded-lg" style="background: linear-gradient(135deg, #dbeafe, #bfdbfe);">
                <div style="font-size: 2rem; font-weight: 700; color: #1e40af;"><%= (locals.stats && stats.total) || 0 %></div>
                <div style="font-size: 0.875rem; color: #1e40af;">Total Expenses</div>
            </div>
            <div class="text-center p-3 rounded-lg" style="background: linear-gradient(135deg, #d1fae5, #a7f3d0);">
                <div style="font-size: 2rem; font-weight: 700; color: #065f46;"><%= (locals.stats && stats.approved) || 0 %></div>
                <div style="font-size: 0.875rem; color: #065f46;">Approved</div>
            </div>
            <div class="text-center p-3 rounded-lg" style="background: linear-gradient(135deg, #fef3c7, #fde68a);">
                <div style="font-size: 2rem; font-weight: 700; color: #92400e;"><%= (locals.stats && stats.pending) || 0 %></div>
                <div style="font-size: 0.875rem; color: #92400e;">Pending</div>
            </div>
            <div class="text-center p-3 rounded-lg" style="background: linear-gradient(135deg, #fee2e2, #fecaca);">
                <div style="font-size: 2rem; font-weight: 700; color: #991b1b;"><%= (locals.stats && stats.rejected) || 0 %></div>
                <div style="font-size: 0.875rem; color: #991b1b;">Rejected</div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="card">
        <h3 class="card-title">Recent Activity</h3>
        <div style="space-y: 1rem;">
            <% if (locals.recentActivity && recentActivity.length > 0) { %>
                <% recentActivity.forEach(item => { %>
                    <div class="d-flex align-center" style="padding: 0.75rem; background: #f8fafc; border-radius: 0.5rem; margin-bottom: 0.5rem;">
                        <div
                            style="
                                width: 8px;
                                height: 8px;
                                border-radius: 50%;
                                margin-right: 0.75rem;
                                background: <%= item.status === 'Approved' ? '#10b981' : item.status === 'Rejected' ? '#ef4444' : '#f59e0b' %>;
                            ">
                        </div>
                        <div>
                            <div style="font-weight: 600;"><%= item.title %></div>
                            <div style="font-size: 0.875rem; color: #64748b;"><%= new Date(item.date).toLocaleString() %></div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="padding: 0.75rem; background: #f8fafc; border-radius: 0.5rem; color: #64748b;">
                    No recent activity yet.
                </div>
            <% } %>
        </div>
    </div>
</div>

<!-- Notifications -->
<div class="card">
    <h2 class="card-title">Notifications</h2>
    <div style="space-y: 1rem;">
        <% if (locals.notifications && notifications.length > 0) { %>
            <% notifications.forEach(item => { %>
                <div class="d-flex align-center" style="padding: 0.75rem; background: #f8fafc; border-radius: 0.5rem; margin-bottom: 0.5rem;">
                    <div
                        style="
                            width: 8px;
                            height: 8px;
                            border-radius: 50%;
                            margin-right: 0.75rem;
                            background: <%= item.status === 'Approved' ? '#10b981' : item.status === 'Rejected' ? '#ef4444' : '#f59e0b' %>;
                        ">
                    </div>
                    <div>
                        <div style="font-weight: 600;"><%= item.title %></div>
                        <div style="font-size: 0.875rem; color: #64748b;"><%= new Date(item.date).toLocaleString() %></div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="padding: 0.75rem; background: #f8fafc; border-radius: 0.5rem; color: #64748b;">
                No notifications yet.
            </div>
        <% } %>
    </div>
</div>

<!-- Submit New Expense -->
<div class="card">
    <h2 class="card-title">Submit New Expense</h2>
    <form action="/expenses/submit" method="POST" enctype="multipart/form-data" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
        <% const companyCurrency = (locals.companySettings && companySettings.defaultCurrency) || ''; %>
        <% const autoApproveEnabled = (locals.companySettings && companySettings.autoApproveEnabled) || false; %>
        <% const autoApproveLimit = (locals.companySettings && companySettings.autoApproveUnderAmount) || 0; %>
        <div class="form-group">
            <label for="amount">Amount <span class="required-marker">*</span></label>
            <input type="number" step="0.01" id="amount" name="amount" class="form-control" placeholder="0.00" required>
            <% if (autoApproveEnabled && autoApproveLimit > 0) { %>
                <small class="field-hint">Expenses up to <%= autoApproveLimit %><%= companyCurrency ? ` ${companyCurrency}` : '' %> are auto-approved.</small>
            <% } %>
        </div>
        <div class="form-group">
            <label for="currency">Currency <span class="required-marker">*</span></label>
            <select id="currency" name="currency" class="form-control" required>
                <option value="">Select Currency</option>
                <option value="USD">USD - US Dollar</option>
                <option value="EUR">EUR - Euro</option>
                <option value="GBP">GBP - British Pound</option>
                <option value="INR">INR - Indian Rupee</option>
                <option value="JPY">JPY - Japanese Yen</option>
            </select>
        </div>
        <div class="form-group">
            <label for="category">Category <span class="required-marker">*</span></label>
            <select id="category" name="category" class="form-control" required>
                <option value="">Select Category</option>
                <option value="Travel">Travel</option>
                <option value="Meals">Meals</option>
                <option value="Accommodation">Accommodation</option>
                <option value="Transportation">Transportation</option>
                <option value="Office Supplies">Office Supplies</option>
                <option value="Other">Other</option>
            </select>
        </div>
        <div class="form-group">
            <label for="date">Date <span class="required-marker">*</span></label>
            <input type="date" id="date" name="date" class="form-control" required>
        </div>
        <div class="form-group" id="other-category-group" style="grid-column: 1 / -1; display: none;">
            <label for="otherCategoryDetails">Explain Other Expense <span class="required-marker">*</span></label>
            <textarea id="otherCategoryDetails" name="otherCategoryDetails" class="form-control" rows="2" placeholder="Explain the expense..."></textarea>
        </div>
        <div class="form-group" id="description-group" style="grid-column: 1 / -1;">
            <label for="description">Description <span class="required-marker">*</span></label>
            <textarea id="description" name="description" class="form-control" rows="3" placeholder="Provide details about this expense..." required></textarea>
        </div>
        <div class="form-group" style="grid-column: 1 / -1;">
            <% const receiptRuleEnabled = (locals.companySettings && companySettings.requireReceiptEnabled) !== false; %>
            <% const receiptThreshold = (locals.companySettings && companySettings.requireReceiptOverAmount) || 0; %>
            <% const receiptAlwaysRequired = receiptRuleEnabled && receiptThreshold <= 0; %>
            <label for="receipt">
                Receipt
                <span class="required-marker" id="receipt-required-marker" style="<%= receiptAlwaysRequired ? '' : 'display:none;' %>">*</span>
                <% if (receiptAlwaysRequired) { %>
                    <span class="field-hint">(Required)</span>
                <% } else if (receiptRuleEnabled) { %>
                    <span class="field-hint">(Required over <%= receiptThreshold %><%= companyCurrency ? ` ${companyCurrency}` : '' %>)</span>
                <% } else { %>
                    <span class="field-hint">(Optional)</span>
                <% } %>
            </label>
            <input type="file" id="receipt" name="receipt" class="form-control" accept="image/*,.pdf" <%= receiptAlwaysRequired ? 'required' : '' %>>
            <div class="d-flex gap-2" style="margin-top: 0.75rem;">
                <button type="button" class="btn btn-secondary" id="receipt-camera-btn" style="padding: 0.5rem 1rem; font-size: 0.875rem;">
                    <i class="fas fa-camera" style="margin-right: 0.5rem;"></i>
                    Take Photo
                </button>
                <button type="button" class="btn btn-secondary" id="receipt-upload-btn" style="padding: 0.5rem 1rem; font-size: 0.875rem;">
                    <i class="fas fa-upload" style="margin-right: 0.5rem;"></i>
                    Upload File
                </button>
            </div>
            <small style="color: #64748b; font-size: 0.875rem;">Supported formats: JPG, PNG, PDF (Max 10MB)</small>
        </div>
        <div style="grid-column: 1 / -1; text-align: center;">
            <button type="submit" class="btn btn-primary" style="padding: 1rem 2rem; font-size: 1.1rem;">
                <i class="fas fa-paper-plane" style="margin-right: 0.5rem;"></i>
                Submit Expense
            </button>
        </div>
    </form>
</div>

<script>
    (function() {
        const categorySelect = document.getElementById('category');
        const otherGroup = document.getElementById('other-category-group');
        const otherInput = document.getElementById('otherCategoryDetails');
        const descriptionGroup = document.getElementById('description-group');
        const descriptionInput = document.getElementById('description');
        const amountInput = document.getElementById('amount');
        const receiptInput = document.getElementById('receipt');
        const cameraBtn = document.getElementById('receipt-camera-btn');
        const uploadBtn = document.getElementById('receipt-upload-btn');
        const receiptRequiredMarker = document.getElementById('receipt-required-marker');

        if (!categorySelect || !otherGroup || !otherInput || !descriptionGroup || !descriptionInput) {
            return;
        }

        function toggleOtherDetails() {
            const isOther = categorySelect.value === 'Other';
            otherGroup.style.display = isOther ? 'block' : 'none';
            otherInput.required = isOther;
            descriptionGroup.style.display = isOther ? 'none' : 'block';
            descriptionInput.required = !isOther;
            if (!isOther) {
                otherInput.value = '';
            } else {
                descriptionInput.value = '';
            }
        }

        categorySelect.addEventListener('change', toggleOtherDetails);
        toggleOtherDetails();

        if (receiptInput && cameraBtn && uploadBtn) {
            cameraBtn.addEventListener('click', () => {
                receiptInput.setAttribute('capture', 'environment');
                receiptInput.click();
            });

            uploadBtn.addEventListener('click', () => {
                receiptInput.removeAttribute('capture');
                receiptInput.click();
            });
        }

        const receiptRuleEnabled = <%= (locals.companySettings && companySettings.requireReceiptEnabled) !== false ? 'true' : 'false' %>;
        const receiptThreshold = <%= (locals.companySettings && companySettings.requireReceiptOverAmount) || 0 %>;

        function updateReceiptRequirement() {
            if (!receiptInput || !amountInput) {
                return;
            }
            if (!receiptRuleEnabled) {
                receiptInput.required = false;
                if (receiptRequiredMarker) {
                    receiptRequiredMarker.style.display = 'none';
                }
                return;
            }
            if (receiptThreshold <= 0) {
                receiptInput.required = true;
                if (receiptRequiredMarker) {
                    receiptRequiredMarker.style.display = 'inline';
                }
                return;
            }
            const amountValue = Number(amountInput.value || 0);
            const isRequired = Number.isFinite(amountValue) && amountValue > receiptThreshold;
            receiptInput.required = isRequired;
            if (receiptRequiredMarker) {
                receiptRequiredMarker.style.display = isRequired ? 'inline' : 'none';
            }
        }

        if (amountInput) {
            amountInput.addEventListener('input', updateReceiptRequirement);
            updateReceiptRequirement();
        }
    })();
</script>

<!-- Expense History -->
<div class="card">
    <div class="d-flex justify-between align-center mb-4">
        <h2 class="card-title">My Expense History</h2>
        <div class="d-flex gap-2">
            <button class="btn btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.875rem;">Filter</button>
            <button class="btn btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.875rem;">Export</button>
        </div>
    </div>
    <div style="overflow-x: auto;">
        <table class="table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if(locals.expenses && expenses.length > 0) { %>
                    <% expenses.forEach(expense => { %>
                        <tr>
                            <td><%= new Date(expense.date).toLocaleDateString() %></td>
                            <td style="font-weight: 600;"><%= expense.amount %> <%= expense.currency %></td>
                            <td><span style="background: #f1f5f9; padding: 0.25rem 0.5rem; border-radius: 0.375rem; font-size: 0.875rem;"><%= expense.category %></span></td>
                            <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= expense.description || 'No description' %></td>
                            <td>
                                <span class="status-badge status-<%= expense.status.toLowerCase() %>">
                                    <%= expense.status %>
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.875rem;">View</button>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 3rem; color: #64748b;">
                            <div style="font-size: 3rem; margin-bottom: 1rem;">📊</div>
                            <div>No expenses found. Submit your first expense above!</div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
