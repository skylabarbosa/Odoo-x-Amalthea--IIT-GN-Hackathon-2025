<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
    <div class="card" style="max-width: 520px; width: 100%; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: white; font-size: 2rem; font-weight: 700;">
                E
            </div>
            <h1 class="card-title" style="margin-bottom: 0.5rem;">Request Access</h1>
            <p style="color: #64748b; font-size: 1rem;">Managers and employees need approval to join</p>
        </div>
        
        <form action="/auth/request-access" method="POST">
            <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" class="form-control" placeholder="Enter your full name" required>
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email" required>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Create a strong password" required>
            </div>
            <div class="form-group">
                <label for="role">Role</label>
                <select id="role" name="role" class="form-control" required>
                    <option value="">Select Role</option>
                    <option value="Employee">Employee</option>
                    <option value="Manager">Manager</option>
                </select>
            </div>

            <div class="form-group" id="company-name-group" style="display: none;">
                <label for="companyName">Company Name</label>
                <input type="text" id="companyName" name="companyName" class="form-control" placeholder="Your company name">
                <small style="color: #64748b; font-size: 0.875rem;">Required for Employee requests</small>
            </div>

            <div class="form-group" id="manager-email-group" style="display: none;">
                <label for="managerEmail">Manager Email</label>
                <input type="email" id="managerEmail" name="managerEmail" class="form-control" placeholder="manager@company.com">
                <small style="color: #64748b; font-size: 0.875rem;">Required for Employee requests</small>
            </div>

            <div class="form-group" id="admin-email-group" style="display: none;">
                <label for="adminEmail">Admin Email</label>
                <input type="email" id="adminEmail" name="adminEmail" class="form-control" placeholder="admin@company.com">
                <small style="color: #64748b; font-size: 0.875rem;">Required for Manager requests</small>
            </div>
            
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem; margin-bottom: 1.5rem;">
                <i class="fas fa-paper-plane" style="margin-right: 0.5rem;"></i>
                Submit Request
            </button>
        </form>
        
        <div style="text-align: center; padding-top: 1.5rem; border-top: 1px solid #e2e8f0;">
            <p style="color: #64748b; margin-bottom: 0;">
                Already have an account?
                <a href="/auth/login" style="color: #6366f1; text-decoration: none; font-weight: 600;">Sign in here</a>
            </p>
        </div>
    </div>
</div>

<script>
    (function() {
        const roleSelect = document.getElementById('role');
        const companyGroup = document.getElementById('company-name-group');
        const managerGroup = document.getElementById('manager-email-group');
        const adminGroup = document.getElementById('admin-email-group');
        const companyInput = document.getElementById('companyName');
        const managerInput = document.getElementById('managerEmail');
        const adminInput = document.getElementById('adminEmail');

        if (!roleSelect || !companyGroup || !managerGroup || !adminGroup || !companyInput || !managerInput || !adminInput) {
            return;
        }

        function updateRoleFields() {
            const role = roleSelect.value;
            const isEmployee = role === 'Employee';
            const isManager = role === 'Manager';

            companyGroup.style.display = isEmployee ? 'block' : 'none';
            managerGroup.style.display = isEmployee ? 'block' : 'none';
            adminGroup.style.display = isManager ? 'block' : 'none';

            companyInput.required = isEmployee;
            managerInput.required = isEmployee;
            adminInput.required = isManager;

            if (!isEmployee) {
                companyInput.value = '';
                managerInput.value = '';
            }
            if (!isManager) {
                adminInput.value = '';
            }
        }

        roleSelect.addEventListener('change', updateRoleFields);
        updateRoleFields();
    })();
</script>
